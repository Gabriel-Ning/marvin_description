<?xml version="1.0"?>
<!-- Marvin with gripper entrypoint — DEFERRED.
     Gripper integration is planned for a future gate.
     This file currently delegates to the arm-only canonical entrypoint. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="marvin">

  <xacro:arg name="connected_to" default="world"/>
  <xacro:arg name="xyz" default="0 0 0"/>
  <xacro:arg name="rpy" default="0 0 0"/>
  <xacro:arg name="ros2_control" default="true"/>
  <xacro:arg name="use_fake_hardware" default="true"/>
  <xacro:arg name="hardware_plugin" default="mock_components/GenericSystem"/>

  <!-- TODO: Add gripper xacro include and macro invocation when
       gripper integration is implemented. For now, delegate to the
       arm-only entrypoint. -->
  <xacro:include filename="$(find marvin_description)/urdf/marvin.urdf.xacro"/>

</robot>
