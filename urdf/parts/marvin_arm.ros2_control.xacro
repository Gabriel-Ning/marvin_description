<?xml version="1.0"?>
<!-- Marvin arm ros2_control block. Exposes 14 arm joints (7 per arm)
     with reserved position/velocity/effort command interfaces and
     position/velocity/effort state interfaces.
     Defaults to mock_components/GenericSystem for fake-hardware validation. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="marvin_arm_ros2_control"
    params="name:='MarvinHardware'
            use_fake_hardware:='true'
            hardware_plugin:='marvin_hardware_interface/MarvinBimanualArmHardware'
            robot_ip:='10.19.0.191'">
    <ros2_control name="${name}" type="system">
      <hardware>
        <xacro:if value="${use_fake_hardware}">
          <plugin>mock_components/GenericSystem</plugin>
        </xacro:if>
        <xacro:unless value="${use_fake_hardware}">
          <plugin>${hardware_plugin}</plugin>
          <param name="use_fake_hardware">false</param>
          <param name="robot_ip">${robot_ip}</param>
        </xacro:unless>
      </hardware>

      <xacro:macro name="configure_joint" params="joint_name">
        <joint name="${joint_name}">
          <command_interface name="position"/>
          <command_interface name="velocity"/>
          <command_interface name="effort"/>
          <state_interface name="position"/>
          <state_interface name="velocity"/>
          <state_interface name="effort"/>
        </joint>
      </xacro:macro>

      <!-- Left arm (7 joints) -->
      <xacro:configure_joint joint_name="Joint1_L"/>
      <xacro:configure_joint joint_name="Joint2_L"/>
      <xacro:configure_joint joint_name="Joint3_L"/>
      <xacro:configure_joint joint_name="Joint4_L"/>
      <xacro:configure_joint joint_name="Joint5_L"/>
      <xacro:configure_joint joint_name="Joint6_L"/>
      <xacro:configure_joint joint_name="Joint7_L"/>

      <!-- Right arm (7 joints) -->
      <xacro:configure_joint joint_name="Joint1_R"/>
      <xacro:configure_joint joint_name="Joint2_R"/>
      <xacro:configure_joint joint_name="Joint3_R"/>
      <xacro:configure_joint joint_name="Joint4_R"/>
      <xacro:configure_joint joint_name="Joint5_R"/>
      <xacro:configure_joint joint_name="Joint6_R"/>
      <xacro:configure_joint joint_name="Joint7_R"/>
    </ros2_control>
  </xacro:macro>
</robot>
