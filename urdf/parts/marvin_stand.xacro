<?xml version="1.0"?>
<!-- Marvin stand: base_link with inertial/visual/collision, column_link,
     and tracking_base_link. Refactored from stand.urdf.xacro. -->
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="marvin_stand" params="description_pkg:=marvin_description">
    <!-- base_link: physical stand base with inertial, visual, and collision -->
    <link
        name="base_link">
        <inertial>
          <origin
            xyz="6.8101E-06 5.7901E-11 0.068902"
            rpy="0 0 0" />
          <mass
            value="1.21" />
          <inertia
            ixx="0.00393"
            ixy="1.5099E-09"
            ixz="-3.4422E-07"
            iyy="0.0047631"
            iyz="8.9145E-13"
            izz="0.0034321" />
        </inertial>
        <visual>
          <origin
            xyz="0 0 0"
            rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://${description_pkg}/meshes/base/base_link.STL" />
          </geometry>
        </visual>
        <collision>
          <origin
            xyz="0 0 0"
            rpy="0 0 0" />
          <geometry>
            <mesh
              filename="package://${description_pkg}/meshes/base/base_link.STL" />
          </geometry>
        </collision>
      </link>

    <link name="tracking_base_link"/>
    <joint name="base_to_tracking_base" type="fixed">
      <parent link="base_link"/>
      <child link="tracking_base_link"/>
      <origin xyz="0 0 -1" rpy="0 0 0"/>
    </joint>

    <link name="column_link">
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.090" length="1.0"/>
      </geometry>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.090" length="1.0"/>
      </geometry>
    </collision>
    </link>
    <joint name="base_to_column" type="fixed">
      <parent link="base_link"/>
      <child link="column_link"/>
      <origin xyz="0 0 -0.50" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>
